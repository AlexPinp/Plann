// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  /// Lecture seule du planning
  AGENT
  /// Modification planning, agents et compétences
  CADRE
  /// Même périmètre que cadre
  REFERENT
  /// Tous les droits
  ADMIN
}

enum ShiftCategory {
  JOUR10
  JOUR12
  JOUR7_50
  NUIT
}

enum AvailabilityType {
  CONGE
  ARRET
  FORMATION
  AUTRE
}

enum PlanningStatus {
  DRAFT
  VALIDATED
  PUBLISHED
}

enum PlanningCommentType {
  CA
  FORMATION
  ABSENCE
  INFO
  BLOCAGE
}

enum PlanningCommentStatus {
  NONE
  PENDING
  APPROVED
  REFUSED
}

enum PlanningCommentVisibility {
  TEAM
  MANAGER
  PRIVATE
}

enum PlanningRhProfile {
  WITH_RTT_VARIABLE_1
  WITH_RTT_VARIABLE_2
  WITH_RTT_FIXED
  WITH_RTT_NIGHT
  WITH_RTT_FORFAIT_JOUR
  WITHOUT_RTT_VARIABLE_1
  WITHOUT_RTT_VARIABLE_2
  WITHOUT_RTT_FIXED
}

enum LeaveRequestType {
  CA
  CF
  CH
  RTT
  REC
  AUTRE
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REFUSED
  CANCELLED
}

enum CommentaryStatus {
  TODO
  IN_PROGRESS
  DONE
}

/// Métier d'une équipe (infirmier ou aide-soignant)
enum TeamJob {
  IDE
  AS
}

/// Rythme de travail principal d'une équipe (jour ou nuit)
enum TeamRhythm {
  JOUR
  NUIT
}

model User {
  id                  String         @id @default(cuid())
  firstName           String
  lastName            String
  email               String         @unique
  /// Identifiant Supabase Auth (auth.users.id) — lie le compte applicatif à l’agent
  authUserId          String?        @unique
  role                UserRole       @default(AGENT)
  active              Boolean        @default(true)
  /// Temps de travail en pourcentage (100 = temps plein)
  workPercentage      Int            @default(100)
  /// Libellé du bloc (équipe / pole) pour la vue planning admin type grille mensuelle
  planningGroupLabel  String?
  /// Couleur de fond de la colonne noms (#hex), ex. #c8e6c9
  planningGroupColor  String?
  /// Ordre d'affichage dans le groupe puis entre groupes
  displayOrder        Int            @default(0)
  /// Numero de trame cyclique attribue (1..33)
  planningTemplateNumber Int?
  /// Activer le mode alternance A/B (ex: SMUR/Urgences)
  isAlternant         Boolean        @default(false)
  /// Duree d'un bloc avant bascule A/B (en semaines), ex: 6
  alternanceCycleWeeks Int           @default(6)
  /// Date d'ancrage du cycle alternant (lundi de demarrage recommande)
  alternanceAnchorDate DateTime?
  /// Decalage de phase (0 ou 1) pour inverser deux binomes
  alternancePhase      Int           @default(0)
  /// Trame appliquee pendant l'etat A
  planningTemplateNumberA Int?
  /// Trame appliquee pendant l'etat B
  planningTemplateNumberB Int?
  /// Bloc/equipe pendant l'etat A
  planningGroupLabelA   String?
  /// Bloc/equipe pendant l'etat B
  planningGroupLabelB   String?
  /// Lien direct vers le binome alternant
  alternancePartnerId   String?      @unique
  /// Profil RH CHD pour le calcul des droits/récap (RTT, base horaire, OAT)
  planningRhProfile   PlanningRhProfile @default(WITH_RTT_VARIABLE_1)
  alternancePartner   User?          @relation("AlternancePartner", fields: [alternancePartnerId], references: [id], onDelete: SetNull)
  alternancePartnerOf User?          @relation("AlternancePartner")
  assignments         Assignment[]
  skills         UserSkill[]
  availabilities Availability[]
  leaveRequests  LeaveRequest[]
  decisionsMade  LeaveRequest[] @relation("LeaveRequestDecider")
  auditLogs      AuditLog[]     @relation("AuditActor")
  planningComments PlanningComment[] @relation("PlanningCommentUser")
  planningCommentsCreated PlanningComment[] @relation("PlanningCommentCreator")
  commentaryEntriesCreated CommentaryEntry[] @relation("CommentaryEntryCreator")
  followUpEntriesCreated FollowUpEntry[] @relation("FollowUpEntryCreator")
  /// Appartenance(s) de l'utilisateur aux équipes (IDE jour/nuit, AS jour/nuit, ...)
  teams          UserTeam[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

/// Équipe fonctionnelle du service (IDE jour, IDE nuit, AS jour, AS nuit, ...).
/// Chaque équipe gère de façon indépendante ses trames, ses semaines de planning,
/// ses membres et ses cadres/référents.
model Team {
  id           String             @id @default(cuid())
  /// Identifiant stable utilisé dans les URLs (ex: "ide-jour")
  slug         String             @unique
  /// Libellé affiché (ex: "Infirmiers de jour")
  label        String
  /// Métier IDE / AS
  job          TeamJob
  /// Rythme jour / nuit
  rhythm       TeamRhythm
  /// Couleur d'accent (#hex) pour les UI (sélecteur, badges)
  color        String             @default("#e2e8f0")
  /// Ordre d'affichage (dans le sélecteur d'équipe et les listes)
  displayOrder Int                @default(0)
  members      UserTeam[]
  templates    PlanningTemplate[]
  weeks        PlanningWeek[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

/// Appartenance d'un utilisateur à une équipe.
/// Une personne peut appartenir à plusieurs équipes (ex: IDE jour + IDE nuit) ;
/// l'équipe `isPrimary = true` est l'équipe par défaut à l'ouverture de l'app.
///
/// Les champs de planning (trame, bloc, couleur) sont portés ici parce que
/// chaque équipe a ses propres trames et ses propres libellés de bloc.
/// Le profil alternance A/B (cycle, ancrage, phase, binôme) reste sur User :
/// il est global à la personne et s'applique à toutes ses équipes.
model UserTeam {
  userId                  String
  teamId                  String
  /// Rôle de la personne DANS cette équipe (peut être plus élevé que User.role si besoin)
  roleInTeam              UserRole @default(AGENT)
  /// Équipe d'atterrissage par défaut à la connexion (une seule par user)
  isPrimary               Boolean  @default(false)
  /// Libellé du bloc/équipe interne (colonne noms dans la grille admin)
  planningGroupLabel      String?
  /// Couleur du bloc (#hex)
  planningGroupColor      String?
  /// Ordre d'affichage dans le groupe puis entre groupes
  displayOrder            Int      @default(0)
  /// Numéro de trame cyclique attribué dans cette équipe
  planningTemplateNumber  Int?
  /// Trame appliquée pendant l'état alternant A
  planningTemplateNumberA Int?
  /// Trame appliquée pendant l'état alternant B
  planningTemplateNumberB Int?
  /// Bloc/équipe pendant l'état A
  planningGroupLabelA     String?
  /// Bloc/équipe pendant l'état B
  planningGroupLabelB     String?
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team                    Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@id([userId, teamId])
  @@index([teamId])
}

model Skill {
  id        String      @id @default(cuid())
  name      String      @unique
  users     UserSkill[]
  shifts    ShiftSkill[]
  createdAt DateTime    @default(now())
}

model UserSkill {
  userId  String
  skillId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([userId, skillId])
}

model ShiftType {
  id          String       @id @default(cuid())
  code        String       @unique
  label       String
  color       String
  startsAt    String
  endsAt      String
  category    ShiftCategory
  assignments Assignment[]
  templateEntries PlanningTemplateEntry[]
  skills      ShiftSkill[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model ShiftSkill {
  shiftTypeId String
  skillId     String
  shiftType   ShiftType @relation(fields: [shiftTypeId], references: [id], onDelete: Cascade)
  skill       Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([shiftTypeId, skillId])
}

model Availability {
  id        String           @id @default(cuid())
  userId    String
  startsAt  DateTime
  endsAt    DateTime
  type      AvailabilityType
  note      String?
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
}

model PlanningWeek {
  id              String         @id @default(cuid())
  /// Équipe à laquelle appartient cette semaine de planning (IDE jour, IDE nuit, ...)
  teamId          String
  weekStart       DateTime
  status          PlanningStatus @default(DRAFT)
  validatedAt     DateTime?
  validatedBy     String?
  /// Nom complet de la personne ayant validé (pour affichage historique)
  validatedByName String?
  publishedAt     DateTime?
  publishedBy     String?
  team            Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  assignments     Assignment[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([teamId, weekStart])
  @@index([teamId])
}

model PlanningTemplate {
  id         String                  @id @default(cuid())
  /// Équipe propriétaire de la trame. Chaque équipe a ses propres numéros 1..N.
  teamId     String
  /// Numéro affiché (unique par équipe)
  number     Int
  /// Libellé libre (ex: "SMUR A", "Binome JM")
  label      String
  /// Durée du cycle en semaines (la trame contient cycleWeeks * 7 entrées)
  cycleWeeks Int                     @default(52)
  team       Team                    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  entries    PlanningTemplateEntry[]
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt

  @@unique([teamId, number])
  @@index([teamId])
}

model PlanningTemplateEntry {
  id          String           @id @default(cuid())
  templateId  String
  dayOffset   Int
  shiftTypeId String?
  template    PlanningTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  shiftType   ShiftType?       @relation(fields: [shiftTypeId], references: [id], onDelete: SetNull)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([templateId, dayOffset])
  @@index([shiftTypeId])
}

model Assignment {
  id             String      @id @default(cuid())
  planningWeekId String
  shiftTypeId    String
  userId         String?
  date           DateTime
  note           String?
  planningWeek   PlanningWeek @relation(fields: [planningWeekId], references: [id], onDelete: Cascade)
  shiftType      ShiftType    @relation(fields: [shiftTypeId], references: [id], onDelete: Restrict)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([userId, date])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String
  details   String?
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
}

model LeaveRequest {
  id        String             @id @default(cuid())
  userId    String
  decidedById String?
  decidedByName String?
  type      LeaveRequestType
  startsAt  DateTime
  endsAt    DateTime
  note      String?
  decisionNote String?
  status    LeaveRequestStatus @default(PENDING)
  decidedAt DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  decidedBy User?              @relation("LeaveRequestDecider", fields: [decidedById], references: [id], onDelete: SetNull)

  @@index([userId, startsAt])
  @@index([createdAt])
  @@index([decidedById])
}

model PlanningComment {
  id         String                   @id @default(cuid())
  userId     String
  date       DateTime
  type       PlanningCommentType
  status     PlanningCommentStatus    @default(NONE)
  visibility PlanningCommentVisibility @default(TEAM)
  text       String
  createdById String?
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  user       User                     @relation("PlanningCommentUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy  User?                    @relation("PlanningCommentCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([date])
  @@index([createdById])
}

model CommentaryEntry {
  id            String           @id @default(cuid())
  monthLabel    String?
  datesLabel    String?
  subject       String
  personnel     String?
  trainer       String?
  comment       String?
  status        CommentaryStatus @default(TODO)
  createdById   String?
  createdByName String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  createdBy     User?            @relation("CommentaryEntryCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
  @@index([createdById])
}

model FollowUpEntry {
  id            String    @id @default(cuid())
  subject       String
  personnel     String?
  lastDate      DateTime?
  lastBy        String?
  nextDate      DateTime?
  nextBy        String?
  note          String?
  createdById   String?
  createdByName String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdBy     User?     @relation("FollowUpEntryCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([createdById])
  @@index([nextDate])
}
